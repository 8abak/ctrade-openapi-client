# Runtime directories. Keep these outside the git checkout on EC2.
DATAVIS_RESEARCH_RUNTIME_DIR=/home/ec2-user/datavis-research
DATAVIS_RESEARCH_ARTIFACT_DIR=/home/ec2-user/datavis-research/artifacts
DATAVIS_RESEARCH_JOURNAL_DIR=/home/ec2-user/datavis-research/journals
DATAVIS_RESEARCH_LOG_DIR=/home/ec2-user/datavis-research/logs

# Database and symbol.
DATABASE_URL=postgresql://babak:babak33044@localhost:5432/trading
DATAVIS_RESEARCH_SYMBOL=XAUUSD

# Calm loop sizing.
DATAVIS_RESEARCH_SEED_SLICE_ROWS=5000
DATAVIS_RESEARCH_SEED_WARMUP_ROWS=160
DATAVIS_RESEARCH_MAX_SLICE_ROWS=40000
DATAVIS_RESEARCH_MAX_SLICE_OFFSET_ROWS=320000
DATAVIS_RESEARCH_SLICE_LADDER=5000,10000,20000,40000
DATAVIS_RESEARCH_MAX_WARMUP_ROWS=600
DATAVIS_RESEARCH_WRITE_BATCH_ROWS=200
DATAVIS_RESEARCH_CHUNK_ROWS=250
DATAVIS_RESEARCH_CHUNK_SLEEP_SECONDS=0.05
DATAVIS_RESEARCH_MIN_RUNS_BEFORE_STOP=5
DATAVIS_RESEARCH_MAX_NEXT_JOBS=4
DATAVIS_RESEARCH_MAX_HISTORY_RUNS=16
DATAVIS_RESEARCH_FAILED_DIRECTION_STOP_COUNT=3
DATAVIS_RESEARCH_ITERATION_BUDGET=8

# Polling and DB safety.
DATAVIS_RESEARCH_WORKER_POLL_SECONDS=4
DATAVIS_RESEARCH_ORCHESTRATOR_POLL_SECONDS=6
DATAVIS_RESEARCH_SUPERVISOR_POLL_SECONDS=6
DATAVIS_RESEARCH_STATEMENT_TIMEOUT_MS=12000
DATAVIS_RESEARCH_LOCK_TIMEOUT_MS=3000

# OpenAI supervisor.
OPENAI_API_KEY=
DATAVIS_RESEARCH_OPENAI_MODEL=
DATAVIS_RESEARCH_OPENAI_ENDPOINT=https://api.openai.com/v1/responses
DATAVIS_RESEARCH_OPENAI_API_STYLE=responses
DATAVIS_RESEARCH_OPENAI_MAX_OUTPUT_TOKENS=900
DATAVIS_RESEARCH_OPENAI_TIMEOUT_SECONDS=45
DATAVIS_RESEARCH_SUPERVISOR_MAX_BRIEFING_CHARS=24000

# Optional service identifiers.
DATAVIS_RESEARCH_WORKER_NAME=research-worker
DATAVIS_RESEARCH_ORCHESTRATOR_NAME=research-orchestrator
DATAVIS_RESEARCH_SUPERVISOR_NAME=research-supervisor
