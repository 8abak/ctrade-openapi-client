# Private control API. Bind loopback-only unless you explicitly front it with authenticated access.
DATAVIS_CONTROL_API_HOST=127.0.0.1
DATAVIS_CONTROL_API_PORT=8010
DATAVIS_CONTROL_API_TOKEN=

# Runtime directories.
DATAVIS_CONTROL_RUNTIME_DIR=/home/ec2-user/datavis-control
DATAVIS_CONTROL_ARTIFACT_DIR=/home/ec2-user/datavis-control/artifacts
DATAVIS_CONTROL_JOURNAL_DIR=/home/ec2-user/datavis-control/journals
DATAVIS_CONTROL_LOG_DIR=/home/ec2-user/datavis-control/logs

# Optional explicit env file paths.
DATAVIS_CONTROL_ENV_FILE=/etc/datavis-control.env
DATAVIS_CONTROL_SHARED_ENV_FILE=/etc/datavis.env
DATAVIS_CONTROL_RESEARCH_ENV_FILE=/etc/datavis-research.env

# Loop cadence and guardrails.
DATAVIS_CONTROL_ENABLE_LOOP=1
DATAVIS_CONTROL_POLL_SECONDS=15
DATAVIS_CONTROL_MAX_RETRIES_PER_INCIDENT=3
DATAVIS_CONTROL_MAX_PATCH_FILES=2
DATAVIS_CONTROL_MAX_PATCH_LINE_CHANGES=120
DATAVIS_CONTROL_MAX_PATCH_BYTES=20000
DATAVIS_CONTROL_MAX_RESTARTS_PER_HOUR=6
DATAVIS_CONTROL_MAX_ROLLBACKS_PER_INCIDENT=2
DATAVIS_CONTROL_JOB_STUCK_SECONDS=1800
DATAVIS_CONTROL_DECISION_STUCK_SECONDS=1800
DATAVIS_CONTROL_RECENT_FAILURE_WINDOW_SECONDS=21600
DATAVIS_CONTROL_MAX_CONTEXT_CHARS=20000
DATAVIS_CONTROL_MAX_LOG_LINES=40

# Managed service names.
DATAVIS_CONTROL_RESEARCH_SERVICES=research-worker,research-supervisor,research-orchestrator
DATAVIS_CONTROL_API_SERVICE_NAME=research-control
DATAVIS_CONTROL_ORCHESTRATOR_SERVICE_NAME=engineering-orchestrator

# Optional dedicated engineering supervisor model. Falls back to the research OpenAI settings when omitted.
DATAVIS_CONTROL_OPENAI_MODEL=
DATAVIS_CONTROL_OPENAI_ENDPOINT=https://api.openai.com/v1/responses
DATAVIS_CONTROL_OPENAI_API_STYLE=responses
DATAVIS_CONTROL_OPENAI_TIMEOUT_SECONDS=45
DATAVIS_CONTROL_OPENAI_MAX_OUTPUT_TOKENS=1200
DATAVIS_CONTROL_OPENAI_TEMPERATURE=0
DATAVIS_CONTROL_SUPERVISOR_MAX_BRIEFING_CHARS=24000
