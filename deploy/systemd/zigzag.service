[Unit]
Description=datavis deterministic centered-window Zig processor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/cTrade
ExecStart=/home/ec2-user/venvs/datavis/bin/python -m datavis.zig_jobs worker --symbol XAUUSD --poll-seconds 1.0 --chunk-size 2000 --log-every 20
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
